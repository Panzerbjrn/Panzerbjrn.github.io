root = true

[*]
indent_style = tab
tab_width = 4
charset = utf-8
end_of_line = crlf
trim_trailing_whitespace = true
insert_final_newline = true

[*.ahk]
charset = utf-8-bom

[*.ps1]
insert_final_newline = true

[*.json]
indent_style = space
tab_width = 2

[*.sql]
indent_style = space
tab_width = 4

[*.{tf,tfvars}]
indent_style = space
tab_width = 2

[*.yml]
indent_style = space
tab_width = 2

[*.bicep]
indent_style = space
tab_width = 2

[*.sh]
end_of_line = lf
insert_final_newline = true

[*.md]
indent_style = space
tab_width = 2
